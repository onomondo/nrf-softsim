menu "Onomondo SoftSIM Options"

config SOFTSIM
    bool "SoftSIM"
    depends on NVS
    depends on FLASH
    depends on FLASH_MAP
    depends on FLASH_PAGE_LAYOUT
    depends on MPU_ALLOW_FLASH_WRITE
    depends on BUILD_WITH_TFM

if SOFTSIM

config SOFTSIM_AUTO_INIT
    bool "Automatically initialize SoftSIM"
    default y
    help
        Automatically initialize SoftSIM when the modem is powered on.

config SOFTSIM_NRF_DEBUG_LOGS
    bool "Enable verbose debug logs for the nrf-softsim layer"
    default n
    help
        When y, the nrf-softsim layer (SIM HAL, filesystem, crypto) logs at
        DBG level and the deferred log buffer is sized to 5000 bytes. Bumps
        the UART backend buffers too. Production builds should leave this
        disabled.

config SOFTSIM_LIBS_DEBUG_LOGS
    bool "Enable verbose debug logs for the onomondo-uicc library"
    default n
    help
        When y, SS_LOGP messages from the onomondo-uicc library are emitted
        at DBG level via the softsim_uicc Zephyr log module. This is the
        higher-volume layer, so it sizes the deferred log buffer to 16384
        bytes (winning over the nrf sizing when both are enabled). Production
        builds should leave this disabled.

config SOFTSIM_STATIC_PROFILE_ENABLE
    bool "Enable static profile"
    default n
    help
        Enable static profile to use for SoftSIM. Developement only.

config SOFTSIM_STATIC_PROFILE
    string "Static profile"
    depends on SOFTSIM_STATIC_PROFILE_ENABLE
    help
        Static profile to use for SoftSIM. If empty, the profile should be passed during runtime (just once via nrf_softsim_provision)

menu "Options for the onomondo-uicc submodule"

config SOFTSIM_UICC_ENABLE_SANITIZE
    bool "Enable sanitizers in onomondo-uicc"
    default n

config SOFTSIM_UICC_USE_SYSTEM_HEAP
    bool "Use system malloc/free in onomondo-uicc"
    default n

config SOFTSIM_UICC_USE_LOGS
    bool "Enable ss_logp logging in onomondo-uicc"
    default y

config SOFTSIM_UICC_USE_EXPERIMENTAL_SUSPEND_COMMAND
    bool "Enable experimental suspend command in onomondo-uicc"
    default y

config SOFTSIM_UICC_EXTERNAL_CRYPTO_IMPL
    bool "Use external crypto implementation in onomondo-uicc"
    default y

config SOFTSIM_UICC_EXTERNAL_KEY_LOAD
    bool "Enable external key loader in onomondo-uicc"
    default n
    depends on !SOFTSIM_UICC_EXTERNAL_CRYPTO_IMPL

config SOFTSIM_UICC_USE_UTILS
    bool "Build onomondo-uicc utils target"
    default n

config SOFTSIM_UICC_NO_DEFAULT_IMPL
    bool "Build onomondo-uicc with no default implementation"
    default y

config SOFTSIM_UICC_COMPACT_STORAGE
    bool "Use compact storage implementation in onomondo-uicc"
    default y

config SOFTSIM_UICC_BUILD_LIB_ONLY
    bool "Build libraries only in onomondo-uicc"
    default y

endmenu

endif #SOFTSIM

endmenu

# Conditional defaults for per-layer log levels — placed BEFORE each template
# source so they win over the template's `default LOG_DEFAULT_LEVEL` fallback
# (Kconfig: first matching default wins).
config SOFTSIM_NRF_LOG_LEVEL
    default 4 if SOFTSIM_NRF_DEBUG_LOGS

module = SOFTSIM_NRF
module-str = Onomondo-SoftSIM-NRF
source "${ZEPHYR_BASE}/subsys/logging/Kconfig.template.log_config"

config SOFTSIM_LIBS_LOG_LEVEL
    default 4 if SOFTSIM_LIBS_DEBUG_LOGS

module = SOFTSIM_LIBS
module-str = Onomondo-SoftSIM-libs
source "${ZEPHYR_BASE}/subsys/logging/Kconfig.template.log_config"

# Log / UART buffer defaults for SoftSIM-enabled builds. Either debug flag
# bumps them; otherwise the production-friendly sizing applies. These are
# `default` directives so any explicit value in a prj.conf or overlay wins.
if SOFTSIM

config LOG_DEFAULT_LEVEL
    default 1

config LOG_BUFFER_SIZE
    default 16384 if SOFTSIM_LIBS_DEBUG_LOGS
    default 5000 if SOFTSIM_NRF_DEBUG_LOGS
    # neither → Zephyr's own default applies

config LOG_BACKEND_UART_BUFFER_SIZE
    default 1024 if SOFTSIM_NRF_DEBUG_LOGS || SOFTSIM_LIBS_DEBUG_LOGS

config UART_0_NRF_TX_BUFFER_SIZE
    default 512 if SOFTSIM_NRF_DEBUG_LOGS || SOFTSIM_LIBS_DEBUG_LOGS

config LOG_PROCESS_TRIGGER_THRESHOLD
    default 5

endif # SOFTSIM
